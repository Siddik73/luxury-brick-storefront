# ---------------------------------------------------------------------------
# Environment variables for Brickhunter storefront.
# Copy this file to `.env` and fill in real values for local development.
# Vite only exposes variables prefixed with VITE_ to client-side code.
# ---------------------------------------------------------------------------

# The published Spline scene URL for the interactive 3D brick in the Hero
# section (e.g. https://prod.spline.design/<SCENE_ID>/scene.splinecode).
# Required for the 3D scene to load; falls back to a static image if unset
# or on touch devices.
VITE_SPLINE_SCENE_URL=

# Google Analytics tracking ID (optional).
# Leave blank to disable analytics entirely.
VITE_GA_TRACKING_ID=

# Base URL for a backend API (optional, reserved for future use).
# This project currently has no backend — all data is static/client-side.
VITE_API_URL=

# Web3Forms access key for The Commons quotation inquiry form.
# Get a free key at https://web3forms.com (just needs the destination email).
# The form shows a clear "channel not configured" error state if left blank.
VITE_WEB3FORMS_KEY=

# Runtime environment. Vite sets this automatically based on the command
# (`development` for `vite`/`vite dev`, `production` for `vite build`) —
# only override this if you have a specific reason to.
NODE_ENV=development
